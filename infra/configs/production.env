# CREST — Production Environment Overrides
# Applied on top of .env for production deployments
# DO NOT commit actual secrets — use Kubernetes Secrets or AWS Secrets Manager

# Database — use RDS/Cloud SQL endpoint in prod
CREST_DB_URL=postgresql://crest_user:REPLACE_ME@rds-endpoint.us-east-1.rds.amazonaws.com:5432/crest_db

# Redis — use ElastiCache cluster in prod
REDIS_URL=redis://crest-redis.cache.amazonaws.com:6379/0

# Kafka — use MSK endpoint in prod
KAFKA_BOOTSTRAP_SERVERS=b-1.crest-kafka.xyz.kafka.us-east-1.amazonaws.com:9092

# Embedding mode — use real embeddings in prod
EMBEDDING_MODE=openai

# CORS — restrict to production dashboard domain
CORS_ORIGINS=https://crest.unionbank.in

# Frontend — production API URL
NEXT_PUBLIC_API_URL=https://api.crest.unionbank.in
