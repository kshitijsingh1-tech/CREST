# CREST — Staging Environment Overrides
# For Union Bank 6-week pilot — Wk1-2 (staging), Wk3-4 (parallel run), Wk5-6 (go-live)

CREST_DB_URL=postgresql://crest_user:REPLACE_ME@staging-postgres:5432/crest_db_staging
REDIS_URL=redis://staging-redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=staging-kafka:9092
EMBEDDING_MODE=openai
CORS_ORIGINS=https://crest-staging.unionbank.in
NEXT_PUBLIC_API_URL=https://api-staging.crest.unionbank.in

# Staging SLA override — 72hr instead of 720hr for faster pilot testing
# Override per complaint via sla_hours field in the ingest payload
