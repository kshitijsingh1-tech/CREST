# CREST environment variables
# Copy to .env and fill in values before running.

# Database
CREST_DB_URL=postgresql://crest_user:crest_pass@localhost:5432/crest_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=crest-ingest-group

# AI APIs
GROQ_API_KEY=gsk-your-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CLASSIFIER_MODEL=openai/gpt-oss-20b
GROQ_DRAFT_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-your-key-here

# Embedding mode: mock | openai
EMBEDDING_MODE=mock
EMBED_BATCH_SIZE=64
CREST_USE_PGVECTOR=1
CREST_DEV_MOCK=1
CREST_RAG_DATASET_DIR=ragdataset
CREST_RAG_CHUNK_SIZE=1200
CREST_RAG_CHUNK_OVERLAP=200
CREST_DIRECT_INGEST_URL=http://127.0.0.1:8000/api/complaints/ingest

# WhatsApp Cloud API (Meta)
WA_VERIFY_TOKEN=crest_verify_2026
WA_APP_SECRET=
WA_ACCESS_TOKEN=

# Twitter / X
TWITTER_BEARER_TOKEN=
TWITTER_BANK_HANDLE=@UnionBankTweets

# Email (IMAP)
# For Gmail, enable IMAP and create an app password.
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=your-inbox@gmail.com
EMAIL_IMAP_PASSWORD=
EMAIL_POLL_INTERVAL_SECS=60

# Email replies (SMTP)
# These can reuse the same Gmail mailbox and app password as IMAP.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-inbox@gmail.com
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_STARTTLS=1
EMAIL_FROM_EMAIL=your-inbox@gmail.com
EMAIL_FROM_NAME=CREST Support

# Alerts
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
SLA_ALERT_EMAIL=grievance-head@unionbank.in
FROM_EMAIL=crest-alerts@unionbank.in

# Frontend
# Leave NEXT_PUBLIC_API_URL blank when the browser should use the same Next.js origin.
NEXT_PUBLIC_API_URL=
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# API
CORS_ORIGINS=http://localhost:3000,https://your-public-domain.example
# Set to 1 only when the backend stays on 127.0.0.1 behind a local tunnel or reverse proxy.
CORS_ALLOW_ALL=0
