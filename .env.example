# CREST — Environment Variables
# Copy to .env and fill in values before running

# ── Database ───────────────────────────────────────────────
CREST_DB_URL=postgresql://crest_user:crest_pass@localhost:5432/crest_db

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=crest-ingest-group

# ── AI APIs ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Embedding mode: mock (no API calls) | openai | anthropic
EMBEDDING_MODE=mock

# ── WhatsApp Cloud API (Meta) ──────────────────────────────
WA_VERIFY_TOKEN=crest_verify_2026
WA_APP_SECRET=
WA_ACCESS_TOKEN=

# ── Twitter / X ────────────────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_BANK_HANDLE=@UnionBankTweets

# ── Email (IMAP) ───────────────────────────────────────────
EMAIL_IMAP_HOST=imap.unionbank.in
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=grievances@unionbank.in
EMAIL_IMAP_PASSWORD=

# ── Alerts ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
SLA_ALERT_EMAIL=grievance-head@unionbank.in
FROM_EMAIL=crest-alerts@unionbank.in

# ── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── API ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
